# --- Neon (online PostgreSQL) ---
# Same setup as pos-backend: grab both from your Neon dashboard.
# DATABASE_URL = pooled connection (hostname has "-pooler") - used by the app
# DIRECT_URL   = direct connection (no "-pooler") - used only for migrations

DATABASE_URL="postgresql://<user>:<password>@<endpoint>-pooler.<region>.aws.neon.tech/<dbname>?sslmode=require"
DIRECT_URL="postgresql://<user>:<password>@<endpoint>.<region>.aws.neon.tech/<dbname>?sslmode=require"

JWT_SECRET="change_this_to_a_long_random_string"
PORT=5000
NODE_ENV=development

# M-Pesa (Daraja API) - leave as-is for simulation mode, fill in for real STK push
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=
MPESA_SIMULATE=true

# Pesapal - leave as-is for simulation mode, fill in for real hosted redirect
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_CALLBACK_URL=
PESAPAL_SIMULATE=true
